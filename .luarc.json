{
  "runtime.version": "LuaJIT",
  "runtime.path": [
    "lua/?.lua",
    "lua/?/init.lua"
  ],
  "diagnostics.globals": [
    "vim",
    "Snacks"
  ],
  "workspace.library": [
    "$VIMRUNTIME",
    "${3rd}/luv/library",
    "${3rd}/luassert/library"
  ],
  "workspace.checkThirdParty": false,
  "workspace.preloadFileSize": 2000,
  "workspace.maxPreload": 10000,
  "workspace.ignoreDir": [
    "tests/mocks"
  ]
}
